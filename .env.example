# ==============================================================================
# STICKERIN BOT - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy file ini menjadi ".env" lalu sesuaikan nilainya dengan kebutuhan Anda.
# Jangan pernah membagikan file ".env" asli Anda ke repositori publik!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Konfigurasi Dasar Bot
# ------------------------------------------------------------------------------

# Karakter awalan untuk perintah bot (contoh: !, ., /)
# Default: !
PREFIX="!"

# Nama sticker pack default yang dibuat oleh bot
# Default: Stikerin Aja
STICKERIN_BOT_NAME="Stikerin Aja"

# Nama pembuat/author default dari stiker
# Default: Bot
STICKERIN_AUTHOR="Bot"


# ------------------------------------------------------------------------------
# 2. Konfigurasi Lingkungan (Environment & Logging)
# ------------------------------------------------------------------------------

# Lingkungan aplikasi: 'development' atau 'production'
# Pada mode 'development', format log akan lebih rapi (pino-pretty).
# Pada mode 'production', log berupa JSON mentah yang dioptimalkan untuk performa & hemat RAM.
# Default: development
NODE_ENV="development"

# Level logging minimum: 'fatal', 'error', 'warn', 'info', 'debug', 'trace'
# Default: info
LOG_LEVEL="info"


# ------------------------------------------------------------------------------
# 3. Penyimpanan & File System
# ------------------------------------------------------------------------------

# Folder untuk menyimpan kredensial autentikasi WhatsApp (Baileys)
# Default: ./auth
# Catatan: jika TURSO_DATABASE_URL diisi, auth akan disimpan di Turso dan AUTH_DIR
# hanya dipakai sebagai fallback.
AUTH_DIR="./auth"

# Penyimpanan session WhatsApp di Turso/libSQL agar tidak perlu scan ulang
# setelah redeploy/restart di hosting stateless seperti Koyeb.
# Kosongkan TURSO_DATABASE_URL untuk memakai AUTH_DIR lokal.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""
TURSO_AUTH_SESSION_ID="default"

# Folder sementara (temp) untuk memproses media sebelum dikirim
# Default: ./temp
TEMP_DIR="./temp"

# Batas waktu retensi file sementara (dalam menit) sebelum dihapus otomatis
# Default: 5
KEEP_TEMP_MINUTES=5

# Batas maksimum ukuran file media yang diizinkan untuk diunduh (dalam bytes)
# Contoh: 10485760 bytes = 10 MB
# Default: 10485760
MAX_FILE_SIZE=10485760

# Target ukuran hasil stiker animasi sebelum bot mencoba kompres otomatis.
# Bot tidak menolak jika tetap lebih besar; ia akan mengirim hasil terkecil.
# Default: 950000 (~950 KB)
ANIMATED_STICKER_TARGET_BYTES=950000
