# ==============================================================================
# STICKERIN BOT - ENVIRONMENT VARIABLES TEMPLATE
# ==============================================================================
# Copy file ini menjadi ".env" lalu sesuaikan nilainya dengan kebutuhan Anda.
# Jangan pernah membagikan file ".env" asli Anda ke repositori publik!
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Konfigurasi Dasar Bot
# ------------------------------------------------------------------------------

# Karakter awalan untuk perintah bot (contoh: !, ., /)
# Default: !
PREFIX="!"

# Nama sticker pack default yang dibuat oleh bot
# Default: Stikerin Aja
STICKERIN_BOT_NAME="Stikerin Aja"

# Nama pembuat/author default dari stiker
# Default: Bot
STICKERIN_AUTHOR="Bot"


# ------------------------------------------------------------------------------
# 2. Konfigurasi Lingkungan (Environment & Logging)
# ------------------------------------------------------------------------------

# Lingkungan aplikasi: 'development' atau 'production'
# Pada mode 'development', format log akan lebih rapi (pino-pretty).
# Pada mode 'production', log berupa JSON mentah yang dioptimalkan untuk performa & hemat RAM.
# Default: development
NODE_ENV="development"

# Level logging minimum: 'fatal', 'error', 'warn', 'info', 'debug', 'trace'
# Default: info
LOG_LEVEL="info"


# ------------------------------------------------------------------------------
# 3. Penyimpanan & File System
# ------------------------------------------------------------------------------

# Folder untuk menyimpan kredensial autentikasi WhatsApp (Baileys)
# Default: ./auth
# Catatan: jika TURSO_DATABASE_URL diisi, auth akan disimpan di Turso dan AUTH_DIR
# hanya dipakai sebagai fallback.
AUTH_DIR="./auth"

# Penyimpanan session WhatsApp di Turso/libSQL agar tidak perlu scan ulang
# setelah redeploy/restart di hosting stateless seperti Koyeb.
# Kosongkan TURSO_DATABASE_URL untuk memakai AUTH_DIR lokal.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""
TURSO_AUTH_SESSION_ID="default"

# ------------------------------------------------------------------------------
# 3A. Group Scheduler & Birthday Takeover
# ------------------------------------------------------------------------------

# Target group for automatic News, Reddit, FX, and Birthday deliveries.
GROUP_JID="120363xxxxxxxx@g.us"

# Birthday records and takeover are stored in the same Turso database as the bot.
BIRTHDAY_FEATURE_ENABLED=true
BIRTHDAY_TAKEOVER_ENABLED=true
# Optional media; missing files fall back to text and the URL below.
BIRTHDAY_SONG_URL="https://youtu.be/IzvZ0gOXiNA"
BIRTHDAY_AUDIO_PATH="./assets/birthday/selamat_ulang_tahun.mp3"
BIRTHDAY_CARD_PATH=""
BIRTHDAY_STICKER_PATH=""
BIRTHDAY_WISH_MAX_LENGTH=500

# Folder sementara (temp) untuk memproses media sebelum dikirim
# Default: ./temp
TEMP_DIR="./temp"

# Batas waktu retensi file sementara (dalam menit) sebelum dihapus otomatis
# Default: 5
KEEP_TEMP_MINUTES=5

# Batas maksimum ukuran file media yang diizinkan untuk diunduh (dalam bytes)
# Contoh: 10485760 bytes = 10 MB
# Default: 10485760
MAX_FILE_SIZE=10485760

# Target ukuran hasil stiker animasi sebelum bot mencoba kompres otomatis.
# Bot tidak menolak jika tetap lebih besar; ia akan mengirim hasil terkecil.
# Default: 950000 (~950 KB)
ANIMATED_STICKER_TARGET_BYTES=950000


# ------------------------------------------------------------------------------
# 4. Groq AI News Editor
# ------------------------------------------------------------------------------

# API key utama untuk Groq (wajib)
GROQ_API_KEY_PRIMARY=

# API key cadangan — digunakan jika primary gagal (401, 403, timeout, 5xx)
GROQ_API_KEY_SECONDARY=

# Model Groq untuk editing berita
# Default: openai/gpt-oss-120b
GROQ_MODEL=openai/gpt-oss-120b

# Timeout request Groq dalam milidetik
# Default: 30000
GROQ_TIMEOUT_MS=30000

# Maksimum token untuk completion Groq
# Default: 1400
GROQ_MAX_COMPLETION_TOKENS=1400

# Aktifkan Groq AI Editor (false untuk langsung fallback)
# Default: true
GROQ_EDITOR_ENABLED=true


# ------------------------------------------------------------------------------
# 5. You.com Web Search API (untuk Reddit Discovery & News Service)
# ------------------------------------------------------------------------------

# API key untuk You.com Web Search (ydc-index.io)
# Diperlukan untuk Reddit Sticker Discovery dan News Service.
# Daftar di https://api.you.com/
YDC_API_KEY=

# ------------------------------------------------------------------------------
# 6. Reddit Sticker Bank (Discovery via You.com — NO Reddit OAuth required)
# ------------------------------------------------------------------------------

# Aktifkan fitur Reddit Sticker Bank
# Default: true
REDDIT_STICKER_ENABLED=true

# ── Discovery Provider ────────────────────────────────────

# Provider discovery: "you" (default)
# Saat ini hanya mendukung You.com Web Search API.
# Reddit OAuth TIDAK diperlukan untuk fitur ini.
REDDIT_DISCOVERY_PROVIDER=you

# Subreddit prioritas untuk discovery yang beragam (meme, reaction, image)
# Default: memes,funny,starterpacks,lotrmemes,therewasanattempt,wholesomememes,ProgrammerHumor,mildlyinfuriating
REDDIT_SEARCH_SUBREDDITS=memes,funny,starterpacks,lotrmemes,therewasanattempt,wholesomememes,ProgrammerHumor,mildlyinfuriating

# Freshness hasil pencarian: "day" atau "week"
# Default: day
REDDIT_SEARCH_FRESHNESS=day

# Fallback freshness jika hasil terlalu sedikit
# Default: week
REDDIT_SEARCH_FALLBACK_FRESHNESS=week

# Jumlah hasil per query pencarian
# Default: 10
REDDIT_SEARCH_RESULTS_PER_QUERY=10

# Maksimum query discovery yang dijalankan bersamaan
# Default: 8 (satu query per subreddit agar tidak terpaku pada satu niche)
REDDIT_SEARCH_MAX_QUERIES=8

# ── Filter Konten ────────────────────────────────────────

# Izinkan konten NSFW (18+)
# Default: true for this opted-in group; set false to block 18+/NSFW results
REDDIT_ALLOW_NSFW=true

# Izinkan post dengan spoiler tag
# Default: true for this opted-in group; set false to block spoiler-tagged posts
REDDIT_ALLOW_SPOILER=true

# ── Generator & Sender ───────────────────────────────────

# Aktifkan scheduler generator (slot diatur oleh count/times di bawah)
# Default: true
REDDIT_STICKER_GENERATOR_ENABLED=true

# Aktifkan scheduler sender (slot diatur oleh count/times di bawah)
# Default: true
REDDIT_STICKER_SENDER_ENABLED=true

# Jumlah stiker yang dibuat scheduler setiap kali berjalan
# Default: 2 per slot (maksimal 10 kandidat baru per hari)
REDDIT_STICKER_GENERATE_COUNT=2

# Jumlah slot generator Reddit per hari; slot disebar otomatis dalam 07:00-22:00 WIB
# Default: 5
REDDIT_STICKER_GENERATIONS_PER_DAY=5

# Opsional: jam generator eksplisit (menggantikan jumlah otomatis)
# REDDIT_STICKER_GENERATE_TIMES=07:00,10:00,13:00,16:00,19:00

# Jumlah stiker yang dikirim scheduler setiap kali berjalan
# Default: 1
REDDIT_STICKER_SEND_COUNT=1

# Jumlah pengiriman Reddit per hari; ubah angka ini untuk mengatur frekuensi
# Default: 10, disebar dari 08:00 sampai 22:00 WIB
REDDIT_STICKER_SENDS_PER_DAY=10

# Opsional: jam kirim eksplisit (menggantikan jumlah otomatis)
# REDDIT_STICKER_SEND_TIMES=08:00,09:33,11:07,12:40,14:13,15:47,17:20,18:53,20:27,22:00

# ── Host Media yang Diizinkan ─────────────────────────────

# Daftar host media Reddit yang diizinkan untuk download (pisahkan dengan koma)
# Default: i.redd.it,preview.redd.it,external-preview.redd.it,v.redd.it
REDDIT_ALLOWED_MEDIA_HOSTS=i.redd.it,preview.redd.it,external-preview.redd.it,v.redd.it

# ── Batas Stiker WhatsApp ─────────────────────────────────

# Maksimum ukuran stiker statis (WebP) dalam bytes
# Default: 100000
STICKER_STATIC_MAX_BYTES=100000

# Maksimum ukuran stiker animasi (animated WebP) dalam bytes
# Default: 500000
STICKER_ANIMATED_MAX_BYTES=500000

# Maksimum durasi stiker animasi dalam detik
# Default: 10
STICKER_ANIMATED_MAX_SECONDS=10

# Target durasi animasi dalam detik
# Default: 6
STICKER_ANIMATED_TARGET_SECONDS=6

# Target FPS animasi
# Default: 12
STICKER_ANIMATED_TARGET_FPS=12

# ── Batas Resource ────────────────────────────────────────

# Maksimum ukuran download media mentah dalam MB
# Default: 25
REDDIT_MEDIA_MAX_DOWNLOAD_MB=25

# Timeout download media dalam milidetik
# Default: 20000
REDDIT_MEDIA_DOWNLOAD_TIMEOUT_MS=20000

# Timeout konversi media dalam milidetik
# Default: 45000
REDDIT_CONVERSION_TIMEOUT_MS=45000

# Maksimum download concurrent
# Default: 2
REDDIT_MAX_CONCURRENT_DOWNLOADS=2

# Maksimum konversi concurrent
# Default: 1
REDDIT_MAX_CONCURRENT_CONVERSIONS=1

# ── Fallback ──────────────────────────────────────────────

# Skip kandidat video jika tidak berhasil resolve URL langsung
# Default: true
REDDIT_SKIP_UNRESOLVED_VIDEO=true

# Fallback ke static-only jika video tidak tersedia
# Default: true
REDDIT_STATIC_ONLY_FALLBACK=true

# ── Cron ──────────────────────────────────────────────────

# Aktifkan pengiriman scheduler Reddit (nama variabel dipertahankan untuk kompatibilitas)
# Default: true
REDDIT_STICKER_CRON_ENABLED=true

# ── Opsional: Reddit OAuth (untuk fitur lain di masa depan) ──
# Variabel di bawah ini TIDAK diperlukan untuk Reddit Sticker Bank.
# Hanya digunakan jika ingin mengaktifkan fitur Reddit API langsung.

# Kredensial Reddit Data API (OAuth) — daftar di https://www.reddit.com/prefs/apps
# Pilih "script" app type.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=WhatsAppGroupStickerBot/1.0 by StickerinBotUser

# Daftar subreddit untuk fitur OAuth-based (tidak digunakan oleh discovery)
REDDIT_DEFAULT_SUBREDDITS=memes,dankmemes,wholesomememes,me_irl,funny,gifs,ProgrammerHumor
REDDIT_FETCH_LIMIT=50
REDDIT_MIN_SCORE=200
REDDIT_MAX_POST_AGE_HOURS=48


# ==============================================================================
# 7. USD/IDR Market Intelligence (Open Exchange Rates + You.com + Groq)
# ==============================================================================

# Open Exchange Rates App ID (daftar di https://openexchangerates.org/)
OPEN_EXCHANGE_RATES_APP_ID=

# ── Feature toggles ────────────────────────────────────
FX_USD_IDR_ENABLED=true
FX_USD_IDR_AUTO_SEND_ENABLED=true
FX_USD_IDR_TARGET_JID=

# Semua scheduler memakai slot absolut Asia/Jakarta dan hanya aktif 07:00-22:00.
# News: 07:00, 12:00, 17:00, 22:00. Nonaktifkan dengan false.
NEWS_SCHEDULER_ENABLED=true

# UJI LOKAL SEMENTARA SAJA — jangan set di Koyeb/production.
# Jika diaktifkan, semua scheduler memakai cadence absolut N menit.
# SCHEDULER_TEST_INTERVAL_MINUTES=5

# ── Provider ───────────────────────────────────────────
FX_RATE_PROVIDER=open_exchange_rates
FX_BASE_CURRENCY=USD
FX_QUOTE_CURRENCY=IDR
FX_API_TIMEOUT_MS=15000
FX_API_MAX_RETRIES=1

# ── Statistics windows ─────────────────────────────────
FX_WINDOW_1D_HOURS=24
FX_WINDOW_7D_DAYS=7
FX_WINDOW_1M_DAYS=30
FX_WINDOW_1Y_DAYS=365
FX_COVERAGE_THRESHOLD_1D=90
FX_COVERAGE_THRESHOLD_7D=85
FX_COVERAGE_THRESHOLD_1M=90
FX_COVERAGE_THRESHOLD_1Y=90

# ── Historical backfill ────────────────────────────────
FX_HISTORY_BACKFILL_ENABLED=true
FX_HISTORY_BACKFILL_MAX_PER_RUN=50
FX_HISTORY_QUOTA_RESERVE=25
FX_MONTHLY_REQUEST_SOFT_LIMIT=975

# ── Market context (You.com + Groq) ────────────────────
FX_MARKET_CONTEXT_ENABLED=true
FX_MARKET_CONTEXT_REFRESH_HOURS=3
FX_MARKET_CONTEXT_MAX_ARTICLES=3
FX_MARKET_CONTEXT_MAX_AGE_HOURS=12

# ── Alert thresholds ───────────────────────────────────
FX_SIGNIFICANT_MOVE_1H_PERCENT=0.15
FX_SIGNIFICANT_MOVE_1D_PERCENT=0.75
FX_NEAR_RANGE_HIGH_PERCENT=80
FX_NEAR_RANGE_LOW_PERCENT=20

# ── Message ────────────────────────────────────────────
FX_HOURLY_MESSAGE_MODE=full
FX_SHOW_NEWS_CONTEXT=true
FX_SHOW_DATA_COVERAGE=true

# ── Lease durations (ms) ───────────────────────────────
FX_LEASE_COLLECT_MS=300000
FX_LEASE_DELIVERY_MS=300000
FX_LEASE_CONTEXT_MS=900000
FX_LEASE_BACKFILL_MS=1800000
